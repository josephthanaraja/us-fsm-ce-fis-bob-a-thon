<risk_assessment_guidelines>
  <overview>
    Risk assessment is the core of this mode. Every notable change must be assigned
    a risk level (HIGH, MEDIUM, or LOW) based on its potential impact and the areas
    it affects.
  </overview>

  <risk_levels>
    <level name="HIGH">
      <description>Changes that could cause security issues, data loss, or system outages</description>
      <indicators>
        <indicator>Authentication or authorization logic changes</indicator>
        <indicator>Database schema modifications or migrations</indicator>
        <indicator>Concurrency primitives (locks, atomics, synchronized blocks)</indicator>
        <indicator>Security-sensitive operations (encryption, validation, sanitization)</indicator>
        <indicator>Error handling removal or weakening</indicator>
        <indicator>Performance-critical hot paths (loops, database queries)</indicator>
        <indicator>External API contract changes</indicator>
        <indicator>Resource management (connections, file handles, memory)</indicator>
        <indicator>Privilege escalation paths</indicator>
      </indicators>
      <examples>
        <example>
          <change>Added new SQL query without parameterization</change>
          <risk>HIGH - SQL injection vulnerability</risk>
        </example>
        <example>
          <change>Removed null check before dereferencing object</change>
          <risk>HIGH - NullPointerException risk</risk>
        </example>
        <example>
          <change>Changed thread synchronization logic</change>
          <risk>HIGH - Race condition potential</risk>
        </example>
      </examples>
    </level>

    <level name="MEDIUM">
      <description>Changes that could cause functional issues or degraded behavior</description>
      <indicators>
        <indicator>Business logic modifications</indicator>
        <indicator>API endpoint changes (parameters, return types)</indicator>
        <indicator>New external dependencies</indicator>
        <indicator>Configuration changes affecting runtime behavior</indicator>
        <indicator>Data validation rule changes</indicator>
        <indicator>Missing test coverage for new code paths</indicator>
        <indicator>Exception handling changes</indicator>
        <indicator>Logging level or content changes</indicator>
        <indicator>Caching strategy modifications</indicator>
      </indicators>
      <examples>
        <example>
          <change>Added new business rule without corresponding tests</change>
          <risk>MEDIUM - Untested behavior change</risk>
        </example>
        <example>
          <change>Modified API response structure</change>
          <risk>MEDIUM - Potential client compatibility issues</risk>
        </example>
        <example>
          <change>Added new dependency library</change>
          <risk>MEDIUM - Supply chain and compatibility concerns</risk>
        </example>
      </examples>
    </level>

    <level name="LOW">
      <description>Changes unlikely to cause functional issues</description>
      <indicators>
        <indicator>Code refactoring with same behavior</indicator>
        <indicator>Documentation updates</indicator>
        <indicator>Test additions or improvements</indicator>
        <indicator>Logging improvements (not level changes)</indicator>
        <indicator>Code style or formatting changes</indicator>
        <indicator>Comment additions or clarifications</indicator>
        <indicator>Variable or method renames (with IDE refactoring)</indicator>
      </indicators>
      <examples>
        <example>
          <change>Extracted method for better readability</change>
          <risk>LOW - Refactoring only</risk>
        </example>
        <example>
          <change>Added unit tests for existing code</change>
          <risk>LOW - Test coverage improvement</risk>
        </example>
        <example>
          <change>Updated README with new instructions</change>
          <risk>LOW - Documentation only</risk>
        </example>
      </examples>
    </level>
  </risk_levels>

  <watch_for_categories>
    <category name="null_safety">
      <description>Potential null pointer exceptions or missing null checks</description>
      <patterns>
        <pattern>Dereferencing without null check</pattern>
        <pattern>Optional.get() without isPresent()</pattern>
        <pattern>Removed null validation</pattern>
        <pattern>Chained method calls on potentially null objects</pattern>
      </patterns>
    </category>

    <category name="concurrency">
      <description>Thread-safety and race condition concerns</description>
      <patterns>
        <pattern>Shared mutable state without synchronization</pattern>
        <pattern>Changed synchronization primitives</pattern>
        <pattern>New thread creation or executor usage</pattern>
        <pattern>Removed locks or synchronization</pattern>
        <pattern>Non-atomic compound operations</pattern>
      </patterns>
    </category>

    <category name="behavior_changes">
      <description>Modifications that alter system behavior</description>
      <patterns>
        <pattern>Changed conditional logic</pattern>
        <pattern>Modified loop conditions</pattern>
        <pattern>Altered return values or types</pattern>
        <pattern>Changed exception handling</pattern>
        <pattern>Modified validation rules</pattern>
      </patterns>
    </category>

    <category name="security_surface">
      <description>Changes that affect security posture</description>
      <patterns>
        <pattern>New input validation or removal of existing validation</pattern>
        <pattern>Authentication or authorization changes</pattern>
        <pattern>Encryption or hashing modifications</pattern>
        <pattern>New external API calls</pattern>
        <pattern>Changed access control logic</pattern>
        <pattern>SQL query construction</pattern>
      </patterns>
    </category>

    <category name="performance_hot_paths">
      <description>Changes in performance-critical code</description>
      <patterns>
        <pattern>Database queries in loops</pattern>
        <pattern>N+1 query patterns</pattern>
        <pattern>Large object allocations in loops</pattern>
        <pattern>Synchronous calls in async contexts</pattern>
        <pattern>Removed caching</pattern>
        <pattern>Changed algorithm complexity</pattern>
      </patterns>
    </category>

    <category name="missing_tests">
      <description>New code without corresponding test coverage</description>
      <patterns>
        <pattern>New methods without tests</pattern>
        <pattern>New classes without test files</pattern>
        <pattern>Changed logic without updated tests</pattern>
        <pattern>New error paths without test coverage</pattern>
      </patterns>
    </category>
  </watch_for_categories>

  <assessment_process>
    <step number="1">
      <action>Identify the type of change</action>
      <questions>
        <question>What is being modified?</question>
        <question>What is the scope of impact?</question>
        <question>What systems or components are affected?</question>
      </questions>
    </step>

    <step number="2">
      <action>Check against high-risk indicators</action>
      <approach>If any high-risk indicator matches, assign HIGH risk immediately</approach>
    </step>

    <step number="3">
      <action>Check against medium-risk indicators</action>
      <approach>If no high-risk match but medium-risk indicators present, assign MEDIUM</approach>
    </step>

    <step number="4">
      <action>Default to LOW if no significant risk indicators</action>
      <approach>But still mention in output if it's a notable change</approach>
    </step>

    <step number="5">
      <action>Identify specific watch-for items</action>
      <approach>List concrete concerns from the watch_for_categories that apply</approach>
    </step>
  </assessment_process>

  <edge_cases>
    <case name="mixed_risk_in_one_file">
      <approach>Report the highest risk level, but mention multiple concerns in watch-for</approach>
    </case>
    <case name="uncertain_risk">
      <approach>Err on the side of caution - assign higher risk and note uncertainty</approach>
    </case>
    <case name="context_dependent_risk">
      <approach>State the risk with context qualifier (e.g., "MEDIUM if used in production path")</approach>
    </case>
  </edge_cases>
</risk_assessment_guidelines>

