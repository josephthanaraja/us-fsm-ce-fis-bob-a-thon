// ═══════════════════════════════════════════════════════════════════
// FIS Bob-a-thon — Dry-run smoke test for the `setup/` toolchain
//
// Three-container pod (build-tools + oc-tools + bob) matching the
// coworker's INSTRUCTOR_SETUP_TZ pattern, with explicit shared
// workspace + workingDir + HOME=/workspace on every container so Bob
// can load custom modes from the checkout.
//
// See DRY_RUN_PLAN.md for the full context. Cluster prereqs:
//   - Namespace:          jenkins
//   - ImageStream:        jenkins/bob-cli:latest
//   - Secret:             bob-cli-credentials (key: BOBSHELL_API_KEY)
//   - Jenkins SA + role:  bob-secret-reader granted
// ═══════════════════════════════════════════════════════════════════

pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins
  containers:
  - name: build-tools
    image: maven:3.9-eclipse-temurin-17
    command: ['sleep', 'infinity']
    workingDir: /workspace
    volumeMounts:
    - name: workspace-volume
      mountPath: /workspace
    env:
    - name: HOME
      value: /workspace
  - name: oc-tools
    image: quay.io/openshift/origin-cli:latest
    command: ['sleep', 'infinity']
    workingDir: /workspace
    volumeMounts:
    - name: workspace-volume
      mountPath: /workspace
    env:
    - name: HOME
      value: /workspace
  - name: bob
    image: image-registry.openshift-image-registry.svc:5000/jenkins/bob-cli:latest
    command: ['sleep', 'infinity']
    workingDir: /workspace
    volumeMounts:
    - name: workspace-volume
      mountPath: /workspace
    env:
    - name: BOBSHELL_API_KEY
      valueFrom:
        secretKeyRef:
          name: bob-cli-credentials
          key: BOBSHELL_API_KEY
    - name: BOB_ACCEPT_LICENSE
      value: "true"
    - name: HOME
      value: /workspace
  volumes:
  - name: workspace-volume
    emptyDir: {}
"""
            defaultContainer 'build-tools'
        }
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh '''
                    echo "=== Workspace contents ==="
                    pwd
                    ls -la
                    echo ""
                    echo "=== .bob/ contents ==="
                    ls -la .bob/
                '''
            }
        }

        stage('Bob mode sanity check') {
            steps {
                container('bob') {
                    sh '''
                        echo "PWD: $(pwd) HOME: $HOME"
                        echo ""
                        echo "=== Can bob see .bob/custom_modes.yaml? ==="
                        ls -la .bob/

                        echo ""
                        echo "=== Invoking bob with solution-code-reviewer mode ==="
                        bob --chat-mode solution-code-reviewer \
                            -p "Reply with exactly: CUSTOM_MODE_WORKING" \
                            --hide-intermediary-output
                    '''
                }
            }
        }
    }

    post {
        always {
            echo "=== Pipeline Complete — result: ${currentBuild.result ?: 'SUCCESS'} ==="
        }
    }
}
