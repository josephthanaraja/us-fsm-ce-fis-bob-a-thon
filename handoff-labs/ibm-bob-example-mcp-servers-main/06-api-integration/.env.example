# API Integration MCP Server - Environment Variables
# Copy this file to .env and fill in your API keys

# WeatherAPI.com API Key (Free tier available - 1M calls/month)
# Get your key at: https://www.weatherapi.com/signup.aspx
WEATHERAPI_KEY=your_weatherapi_key_here

# GitHub Personal Access Token
# Get your token at: https://github.com/settings/tokens
# Required scopes: gist, repo
GITHUB_TOKEN=your_github_token_here

# Trello API Credentials
# Get your API key and token at: https://trello.com/app-key
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here

# Cloudinary Credentials
# Get your credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here