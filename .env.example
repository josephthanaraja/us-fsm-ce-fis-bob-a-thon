# Jira credentials for the Atlassian MCP server.
# Your instructor will provide these three values.
#
# Usage: copy this template to .env (same directory) and fill in the values.
# Bob loads .env automatically on startup, so just save the file and restart
# the IDE.
#
#   cp .env.example .env
#
# .bob/mcp.json references these as ${JIRA_URL}, ${JIRA_USERNAME}, and
# ${JIRA_API_TOKEN}, so values stay out of any committed config.
#
# Do NOT commit .env (already gitignored at the repo root).

# Your Jira site URL (no trailing slash, must include https://)
JIRA_URL=https://your-org.atlassian.net

# Your Jira username — this is the email you log in with
JIRA_USERNAME=your.email@example.com

# Jira API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here
